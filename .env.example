BOT_TOKEN=your_bot_token_here

# PostgreSQL (Docker)
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://booking:change_me@db:5432/bookings

# Admin Panel
ADMIN_USER=admin
ADMIN_PASS=change_me
ADMIN_IDS=

# Working hours
WORK_START=9
WORK_END=18
SAT_WORK_END=14
SUNDAY_CLOSED=true

# Timezone (hours from UTC)
TZ_OFFSET=3

# How many days ahead users can book
BOOKING_AHEAD_DAYS=14

# Reminder hours before appointment (comma-separated)
REMINDER_HOURS=24,2

# Redis for FSM storage
REDIS_URL=redis://redis:6379/0
